		jQuery(function( $ ) {
			$( 'form#order_review' ).submit( () => {
				expiry = $.payment.cardExpiryVal( $( '#wc-netbilling-credit-card-expiry' ).val() );
				expiry_year = expiry.year;
				expiry_month = String(expiry.month).padStart(2, '0');
				$( '#payment_card_expdate_month' ).val( expiry_month );
				$( '#payment_card_expdate_year' ).val( expiry_year );

				if ( $( "input.js-wc-netbilling-credit-card-payment-token:checked" ).val() ) {
					//??
					$( 'form#order_review' ).attr( 'action', '' );
				}
				return true;
			});
		});
		
