    <script>
    function send_recirc_event() {
        var recirc_exists = ['.full-injected-recirc','.floatrecirc', '.recircblock','.recirc-title']
        var run_event = false
        for (let i = 0; i < recirc_exists.length; i++) {
                if (document.querySelector(recirc_exists[i])) {
                    run_event = true
                    break;
                }
        }
        if (run_event) {
            window.gtag('event', 'ICMS Recirc', {
                'send_to': 'G-REMCFGK2V5',
                
                
                    'icms_recirc_group' : '1',
                
                
            })
        } else {
            if (document.querySelector('.ign-recommends-item')) {
                window.gtag('event', 'ICMS Recirc', {
                'send_to': 'G-REMCFGK2V5',
                
                    'icms_recirc_group' : '2',
                
            })  
            }
        } 
    } 
    window.onload = setTimeout(send_recirc_event,0);
       

    function img_find() {
            let page_content = document.querySelector('#id_text')
            var imgs = page_content.querySelectorAll("img");
            var imgSrcs = [];
            var obj = new Object();
            obj.title = "Dragon&#x27;s Dogma 2: A Sphinx egy olyan lény, amelyhez foghatót még nem láthattak a sorozat rajongói - IGN First"

            obj.elements = []
            position = 0;
            for (var i = 0; i < imgs.length; i++) {
                if (imgs[i].parentElement?.classList?.contains('recirc_odd')) {
                    continue
                }
                caption = ''
                imgs[i].dataset.position = position
                position = position+1;
                if (imgs[i].closest('figure')) {
                    let figcaption = imgs[i].closest('figure').querySelector('figcaption')
                    if (figcaption) {
                        caption = figcaption.innerHTML
                    }  else { 
                        caption = imgs[i].alt
                    }
                }
                
                if (imgs[i].dataset.src) {
                    src = imgs[i].dataset.src
                } else if (imgs[i].src) {
                    src = imgs[i].src
                }
                obj.elements.push({'src': src, 'caption': caption});
            }
            return obj
     }
    
  
    initUgwArticle = function() {
         const ugwArticle = new UGW(
             {
                 'invoker': '#id_text img',
                 'json':img_find(),
                  translation: {
                    'images': 'images',
                    'of': 'OF',
                    'fullscreen': 'Fullscreen'
                }
             }
         )
    }
    ICMS.libs.push({
        'url': '/s/js/universal_gallery_widget.js?680',
            'onPageReady': initUgwArticle
    });
    </script>

  <script type="application/ld+json">{"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "item": {"@id": "https://hu.ign.com/news/", "name": "H\u00edrek"}}, {"@type": "ListItem", "position": 2, "item": {"@id": "https://hu.ign.com/dragons-dogma-ii", "name": "Dragon's Dogma II"}}]}</script><script type="application/ld+json">{"@context": "https://schema.org", "@type": "NewsArticle", "mainEntityOfPage": {"@type": "WebPage", "@id": "https://hu.ign.com/dragons-dogma-ii/92723/news/dragons-dogma-2-a-sphinx-egy-olyan-leny-amelyhez-foghatot-meg-nem-lathattak-a-sorozat-rajongoi-ign-f"}, "headline": "Dragon's Dogma 2: A Sphinx egy olyan l\u00e9ny, amelyhez foghat\u00f3t m\u00e9g nem l\u00e1thattak a sorozat rajong\u00f3i - IGN First", "image": [{"@type": "ImageObject", "url": "https://sm.ign.com/ign_hu/screenshot/default/sphinx-ign-first-blogroll-1704932431018_p2vb.jpg", "width": 1280, "height": 720}], "description": "A tud\u00e1sunkat \u00e9s az er\u0151nket egyar\u00e1nt pr\u00f3b\u00e1ra teszi", "datePublished": "2024-01-15 13:50:20+00:00", "inLanguage": "hu", "about": {"@context": "https://schema.org", "@type": "Videogame", "name": "Dragon's Dogma II", "description": "A Dragon\u2019s Dogma II egy leny\u0171g\u00f6z\u0151 j\u00e1t\u00e9k, amely \u2013 ha megszereted zord vil\u00e1g\u00e1t annak boh\u00f3k\u00e1s hib\u00e1ival egy\u00fctt \u2013 nem fog ereszteni hossz\u00fa \u00f3r\u00e1kon, napokon \u00e1t. A f\u0151t\u00f6rt\u00e9net \u00e9rdekes, a mell\u00e9ksz\u00e1lak izgalmasak, \u00e9s az alap j\u00e1t\u00e9kmechanika is j\u00f3l \u00e1tgondolt, ami nem t\u0171r kompromisszumot. A j\u00e1t\u00e9k n\u00e9ha eg\u00e9szen zseni\u00e1lis \u2013 egy ponton p\u00e9ld\u00e1ul m\u00e9rf\u00f6ldeken \u00e1t v\u00edvhatunk egy bossharcot, amihez m\u00e9g hasonl\u00f3t sem l\u00e1ttam \u2013, ugyanakkor pont ez a rendk\u00edv\u00fcli szabads\u00e1g gyakran furcsa v\u00e9geredm\u00e9nyhez, hib\u00e1knak t\u0171n\u0151 szitu\u00e1ci\u00f3khoz vezet. \u00c9s pont ez\u00e9rt hiszem azt, hogy a Dragon\u2019s Dogma megoszt\u00f3 lesz: n\u00e9ha olyan, mintha egy t\u00edz esztend\u0151vel ezel\u0151tti j\u00e1t\u00e9kot \u00faj\u00edtottak volna fel alapos m\u0171gonddal, m\u00e1skor azonban annyira belemer\u00fcl az ember, hogy \u00e9szre sem veszi, hogy \u00f3r\u00e1k teltek m\u00e1r el. De mindent egybevetve a Dragon\u2019s Dogma II egy fantasztikus utaz\u00e1s, \u00e9s egy egyed\u00fcl\u00e1ll\u00f3 fantasy RPG, amihez hasonl\u00f3t eddig legfeljebb a nagy el\u0151d mutatott - k\u00e1r, hogy a mikrotranzakci\u00f3k be\u00e1rny\u00e9kolj\u00e1k a zsenij\u00e9t.", "image": ["https://sm.ign.com/ign_hu/game/d/dragons-do/dragons-dogma-ii_9hwv.jpg"], "applicationCategory": "Game", "publisher": "Capcom", "genre": "RPG"}, "publisher": {"@type": "Organization", "name": "IGN Hungary", "url": "https://hu.ign.com", "logo": {"@type": "ImageObject", "url": "https://hu.ign.com/s/ign/ign_logo_micro.png", "width": 245, "height": 60}}, "author": [{"@type": "Person", "name": "Sz\u00e1ler Martin", "additionalName": "Martin Sz\u00e1ler", "givenName": "Martin", "familyName": "Sz\u00e1ler", "image": "https://sm.ign.com/ign_hu/user/s/szaler-mar/szaler-martin_rnbt.jpg", "url": "https://hu.ign.com/u/szaler-martin"}], "dateModified": ["2024-01-15 13:50:20+00:00"]}</script>
