"translationsLoaded",
() => {
initTranslations();
},
{ once: true }
);
document.addEventListener("DOMContentLoaded", () => {
init();
appendWidgets();
});
window.onload = function () {
debugLog("Window loaded, initing colorthief, smooth scroll links, and check for new translations.");
initSmoothScrollLinks();
useColorThief();
refreshTranslations();
};
