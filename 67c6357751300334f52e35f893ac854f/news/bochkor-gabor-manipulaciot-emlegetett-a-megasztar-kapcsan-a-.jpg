<script>
document.addEventListener("DOMContentLoaded", function() {
const here = document.currentScript || document.scripts[document.scripts.length - 1];
const root = (here.previousElementSibling && here.previousElementSibling.matches('ul.tags'))
? here.previousElementSibling
: (here.closest && here.closest('ul.tags')) || document.querySelector('ul.tags');
if (!root) return;
const HIDDEN_CLS = (typeof HIDDEN !== 'undefined') ? HIDDEN : 'hidden-important';
const visibleItemCount = Number(((window.config && config.articleDetails && config.articleDetails.numberOfVisibleTag) ?? 3));
const items = root.querySelectorAll(".list-item:not(.outside-list)");
const moreButton = root.querySelector("#remaining-count");
const moreButtonIcon = root.querySelector("#more-button-icon");
if (!moreButton || !moreButtonIcon) return;
const remainingCount = items.length - Math.min(items.length, visibleItemCount);
moreButton.textContent = `+${remainingCount}`;
function setListItemVisible(isVisible) {
Array.from(items).forEach((item, index) => {
if (index < visibleItemCount) item.classList.remove(HIDDEN_CLS);
else item.classList.toggle(HIDDEN_CLS, !isVisible);
});
const hideMore = isVisible || remainingCount <= 0;
moreButton.classList.toggle(HIDDEN_CLS, hideMore);
moreButtonIcon.classList.toggle(HIDDEN_CLS, !isVisible || remainingCount <= 0);
moreButton.setAttribute("aria-expanded", isVisible ? "true" : "false");
}
if (remainingCount > 0) setListItemVisible(false);
else setListItemVisible(true);
function focusFirstRevealed() {
const firstRevealed = Array.from(items).slice(visibleItemCount).find(li => !li.classList.contains(HIDDEN_CLS));
if (!firstRevealed) { try { moreButtonIcon.focus(); } catch {} return; }
const focusable = firstRevealed.querySelector('a,button,input,select,textarea,[tabindex]:not([tabindex="-1"])');
if (focusable) { try { focusable.focus(); } catch { focusable.focus(); } }
else {
firstRevealed.setAttribute("tabindex", "-1");
firstRevealed.addEventListener("blur", () => firstRevealed.removeAttribute("tabindex"), { once: true });
try { firstRevealed.focus(); } catch { firstRevealed.focus(); }
}
}
function toggleMore() {
const li0 = items[visibleItemCount];
const isOpening = !!(li0 && li0.classList.contains(HIDDEN_CLS));
setListItemVisible(isOpening);
if (isOpening) requestAnimationFrame(focusFirstRevealed);
else requestAnimationFrame(() => { try { moreButton.focus(); } catch {} });
}
moreButton.addEventListener("click", toggleMore);
moreButton.addEventListener("keydown", function(e) {
const k = e.key;
if (k === "Enter") { e.preventDefault(); toggleMore(); }
else if (k === " " || k === "Spacebar" || e.code === "Space") { e.preventDefault(); }
});
moreButton.addEventListener("keyup", function(e) {
const k = e.key;
if (k === " " || k === "Spacebar" || e.code === "Space") { e.preventDefault(); toggleMore(); }
});
moreButtonIcon.addEventListener("click", toggleMore);
moreButtonIcon.setAttribute("tabindex", "0");
moreButtonIcon.setAttribute("role", "button");
if (!moreButtonIcon.getAttribute("aria-label")) moreButtonIcon.setAttribute("aria-label", "Címkék elrejtése");
moreButtonIcon.addEventListener("keydown", function(e) {
const k = e.key;
if (k === "Enter") { e.preventDefault(); toggleMore(); }
else if (k === " " || k === "Spacebar" || e.code === "Space") { e.preventDefault(); }
});
moreButtonIcon.addEventListener("keyup", function(e) {
const k = e.key;
if (k === " " || k === "Spacebar" || e.code === "Space") { e.preventDefault(); toggleMore(); }
});
});
</script>
