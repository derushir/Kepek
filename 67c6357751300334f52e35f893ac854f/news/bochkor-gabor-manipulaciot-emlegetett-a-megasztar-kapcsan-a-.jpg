if (!baseImage) return
if (baseImage.crossOrigin !== "anonymous") {
baseImage.crossOrigin = "anonymous"
}
if (baseImage.complete) {
processImageWithCanvas(colorThiefObj, targetElement, baseImage, options)
} else {
baseImage.addEventListener("load", () => {
processImageWithCanvas(colorThiefObj, targetElement, baseImage, options)
}, { once: true })
}
