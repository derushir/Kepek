<script>
function initShareButtons() {
const shareButtons = document.querySelectorAll(".shareButton")
const metaDescription = document.querySelector("meta[name='description']")
const descriptionText = metaDescription?.content
const url = window.location.href
shareButtons.forEach((button) => {
button.addEventListener("click", () => share(url, document.title, descriptionText))
button.classList.remove("shareButton")
})
}
const elements = document.querySelectorAll(".wp-block-hvg-custom-image")
const adultContent = document.querySelectorAll(".adult-content-img")
adultContent.forEach((adultContent) => {
adultContent.parentElement.classList.add("min-height-400")
})
const button = {
adult: document.querySelector(".L-button.on_dark"),
underEighteen: document.querySelector(".button-under-eighteen")
}
if (button.adult) {
button.adult.addEventListener("click", function() {
const adultContent = this.closest(".adult-content-img")
if (adultContent) {
adultContent.style.display = "none"
}
elements.forEach((element) => {
element.classList.remove("min-height-400")
})
})
}
if (button.underEighteen) {
button.underEighteen.addEventListener("click", function() {
window.location.href = config.adultContent.underEighteenURL
})
}
document.addEventListener("DOMContentLoaded", function() {
const copyButtonAll = document.querySelectorAll(".copyUrlButton")
copyButtonAll.forEach((copyButton) => {
copyButton.addEventListener("click", () => {
const url = window.location.href
navigator.clipboard
.writeText(url)
.then(() => {
const iconWrapper = copyButton.querySelector(".icon")
const label = copyButton.querySelector(".label")
const originalIconHTML = iconWrapper.innerHTML
const originalLabel = label.textContent
iconWrapper.innerHTML = `<span class="hvg-icon hvg-icon-check"></span>`
label.textContent = getTranslation("articleDetails.socialContent.copiedLink", "Link copied!")
copyButton.classList.add("success")
copyButton.blur()
setTimeout(() => {
copyButton.classList.add("fading")
}, 1500)
setTimeout(() => {
iconWrapper.innerHTML = originalIconHTML
label.textContent = originalLabel
copyButton.classList.remove("success", "fading")
}, 2000)
})
.catch((err) => debugError("Hiba történt a másolás során:", err))
})
})
isArticleSaved(getArticleId())
})
function initClosingWidgetCloseButton() {
const closingWidgetSection = document.querySelector("section.closing-widget")
const closingWidgetCloseButton = document.querySelector("section.closing-widget .close-paywall")
if (closingWidgetCloseButton) {
closingWidgetCloseButton.addEventListener("click", function() {
closingWidgetSection.style.display = "none"
})
}
}
function getArticleId() {
const meta = document.querySelector("meta[property='articleId']")
return meta ? meta.content : null
}
/* -------- SAVE ARTICLE ------------------------------*/
const SAVE_ARTICLE_BUTTON_SELECTOR = ".saveArticleButton"
function saveArticle(wantedState) {
checkAuthOrTryLogin(() => {
loadingSaveArticleButton()
const id = getArticleId()
if (!id) return
fetch(config.apiURL.saveArticle, {
method: wantedState ? "POST" : "DELETE",
credentials: "include",
headers: {
"Content-Type": "application/json",
"Access-Control-Origin": "*"
},
body: JSON.stringify({
id: id
})
})
.then((response) => {
if (!response.ok) {
throw new Error(`HTTP error! Status: ${response.status}`)
}
try {
replaceSaveArticleButton(wantedState)
} catch (e) {
debugError(e)
}
})
.catch((e) => {
debugError(e)
})
.finally(() => loadingSaveArticleButton(false))
})
}
function isArticleSaved(id) {
if (!id) return
fetch(config.apiURL.isArticelSaved, {
method: "POST",
credentials: "include",
headers: {
"Content-Type": "application/json",
"Access-Control-Origin": "*"
},
body: JSON.stringify({ id: id })
})
.then((response) => {
if (!response.ok) {
throw new Error("Network response was not ok")
}
return response.json()
})
.then((has) => {
replaceSaveArticleButton(has)
})
.catch((e) => {
debugError(e)
})
.finally(() => loadingSaveArticleButton(false))
}
function loadingSaveArticleButton(isLoading = true) {
document.querySelectorAll(SAVE_ARTICLE_BUTTON_SELECTOR).forEach((button) => {
button.disabled = isLoading
})
}
function replaceSaveArticleButton(state) {
document.querySelectorAll(SAVE_ARTICLE_BUTTON_SELECTOR).forEach((btn) => {
const shouldHide = state !== btn.classList.contains("active")
btn.classList.toggle(HIDDEN, shouldHide)
})
}
function SetClosingControl() {
const articleWebId = document.head.querySelector("[property~=articleWebId][content]").content
const urlParams = new URLSearchParams(window.location.search)
const giftId = urlParams.get("giftId")
let giftIdToMsgw = ""
if (giftId) {
giftIdToMsgw = "?giftId=" + giftId
}
fetch(window.msgwBaseUrl + "/api/paidcontent/requiredacl/" + articleWebId + giftIdToMsgw, {
method: "GET",
credentials: "include",
headers: {
"Content-Type": "application/json"
}
})
.then(function(response) {
if (!response.ok) {
throw new Error(`HTTP error! Status: ${response.status}`)
}
return response.json()
})
.then(function(requiredAclRes) {
if (requiredAclRes.requiredAcl) {
appendWidget("paywall")
window.paywallConfig.requiredAcl = requiredAclRes.requiredAcl
const fadeLayerDiv = document.createElement("div")
fadeLayerDiv.className = "fade-layer"
document.getElementById("free-body").appendChild(fadeLayerDiv)
appendWidget("closing", () => {
initClosingWidgetCloseButton()
})
}
else {
loadDisqus();
const observer = new MutationObserver((mutations) => {
for (const m of mutations) {
if (m.type === 'attributes' && m.attributeName === 'data-theme') {
requestAnimationFrame(() => loadDisqus());
break;
}
}
});
if (document.body) {
observer.observe(document.body, { attributes: true, attributeFilter: ['data-theme'] });
}
}
})
.catch((error) => {
debugError("Error fetching data:", error.message)
})
}
var disqus_title = document.title;
var disqus_url = (document.querySelector("link[rel='canonical']")?.href) || window.location.href;
var disqus_identifier = window.location.href.split("/").pop().split('?')[0];
function getCurrentTheme() {
return document.body?.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
}
function makeDisqusConfig(theme) {
return function () {
this.language = "hu";
this.page.url = disqus_url;
this.page.identifier = disqus_identifier;
this.page.title = disqus_title;
this.theme = theme;
};
}
function injectDisqusScript(disqusShortName) {
if (document.getElementById('disqus-embed-script')) return;
const disqus_embed = document.createElement('script');
disqus_embed.type = 'text/javascript';
disqus_embed.async = true;
disqus_embed.src = '//' + disqusShortName + '.disqus.com/embed.js';
(document.head || document.body).appendChild(disqus_embed);
}
function loadDisqus(forceTheme) {
if (!document.head.querySelector("[property~=disqusshortname][content]")) return;
const isPreview = document.head.querySelector("[property~=ispreview][content]").content;
const isCommentEnabled = document.head.querySelector("[property~=iscommentenabled][content]").content;
const disqusShortName = document.head.querySelector("[property~=disqusshortname][content]").content;
if (isCommentEnabled == "True" && isPreview != "True") {
if (!isFlutter()) {
const currentTheme = forceTheme || getCurrentTheme();
window.disqus_config = makeDisqusConfig(currentTheme);
if (window.DISQUS) {
window.DISQUS.reset({
reload: true,
config: window.disqus_config
});
} else {
injectDisqusScript(disqusShortName);
console.log('Disqus loaded with theme:', currentTheme);
}
document.getElementById('goToCommentsLi').style.display = 'block';
} else if (isFlutter()) {
checkIfFlutter(".btn-disqus-app-opener[data-action]");
}
}
}
function redirectOutWebview() {
window.open(disqus_url + "#disqus_thread", "_blank");
}
function scrollToHash() {
const HASH = decodeURIComponent(location.hash.slice(1));
if (!HASH) return;
const getOffset = () =>
parseInt(getComputedStyle(document.documentElement)
.getPropertyValue('--sticky-offset')) || 0;
function scrollToEl(el) {
const y = el.getBoundingClientRect().top + window.pageYOffset - getOffset() - 8;
window.scrollTo({ top: y, behavior: 'auto' });
}
function tryScroll() {
const el = document.getElementById(HASH);
if (!el) return false;
const desired = el.getBoundingClientRect().top - getOffset() - 8;
if (Math.abs(desired) > 2) scrollToEl(el);
return true;
}
if (tryScroll()) return;
if (document.fonts?.ready) {
document.fonts.ready.then(tryScroll).catch(()=>{});
}
let tries = 50;
const iv = setInterval(() => {
if (tryScroll() || !--tries) clearInterval(iv);
}, 100);
const mo = new MutationObserver(() => {
if (tryScroll()) mo.disconnect();
});
mo.observe(document.body, { childList: true, subtree: true, attributes: true });
window.addEventListener('load', () => setTimeout(tryScroll, 0), { passive: true });
window.addEventListener('hashchange', () => {
const id = decodeURIComponent(location.hash.slice(1));
if (!id) return;
setTimeout(() => {
const el = document.getElementById(id);
if (el) scrollToEl(el);
}, 0);
}, { passive: true });
}
function SetAvailableUserFunctions() {
fetch(window.msgwBaseUrl + "/api/profile/authorizedUserFunctions", {
method: "GET",
credentials: "include",
headers: {
"Content-Type": "application/json"
}
})
.then(function(response) {
if (!response.ok) {
throw new Error(`HTTP error! Status: ${response.status}`)
}
return response.json()
})
.then(function(functionsResponse) {
if (functionsResponse.authorizedUserFunctions) {
functionsResponse.authorizedUserFunctions.forEach((item) => {
let elementsToShow = Array.from(document.getElementsByClassName(item))
if (elementsToShow) {
elementsToShow.forEach((elToShow) => {
elToShow.classList.remove("createGiftLink")
elToShow.classList.add("createGiftLink-show")
})
}
})
}
})
.catch((error) => {
debugError("Error fetching data:", error.message)
})
}
function SetGiftLinkNotificationIfNeeded() {
const urlParams = new URLSearchParams(window.location.search)
const giftId = urlParams.get("giftId")
if (giftId) {
verifyToken()
.then(() => showGiftLinkNotification("giftlink-info-notification"))
.catch(() => showGiftLinkNotification("giftlink-login-notification"))
}
}
function showGiftLinkNotification(notificationType) {
getPartFromSE(notificationType, notificationType, notificationType, null, function(text) {
let tmpDiv = document.createElement("div")
tmpDiv.innerHTML = text
init(tmpDiv)
window.postMessage({
MessageType: "OnsiteNotification",
Message: {
Title: "",
Content: tmpDiv.innerHTML,
ToastPosition: { Vertical: "top", Horizontal: "center" },
Type: "fix",
Severity: "info",
ToastExpiryInSec: 30,
Closable: true,
FixSticky: true
}
})
})
}
function doGa4Stuff() {
if (typeof fetchAndSendGa4UserDataIfRequired !== "function") {
debugError("fetchAndSendGa4UserDataIfRequired function is not defined.")
return
}
fetchAndSendGa4UserDataIfRequired(ga4FetchCompletedCallback)
}
function processInternalLinks() {
const contentBodies = document.querySelectorAll('.content-body')
const currentDomain = window.location.hostname
contentBodies.forEach(contentBody => {
const links = contentBody.querySelectorAll('a[href]')

links.forEach(link => {
try {
const href = link.getAttribute('href')

const url = new URL(href, window.location.origin)

if (url.hostname === currentDomain) {
link.removeAttribute('target')
}
} catch (error) {
debugError('Error parsing link URL:', error, 'for link:', link.href)
}
})
})
}
function initContentObserver() {
processInternalLinks()
const paidWidget = document.querySelector('paidcontent-widget')
if (paidWidget) {
const observer = new MutationObserver(() => {
processInternalLinks()
})

observer.observe(paidWidget, {
childList: true,
subtree: true
})
}
}
function ga4FetchCompletedCallback() {
let gaTagsArr = document.head.querySelector("[property~=ga4_tags][content]").content.split(",");
let gaColsArr = document.head.querySelector("[property~=ga4_other_columns][content]").content.split(",");
let artLoadEvt = {
"event": "article_loaded",
"article_id": document.head.querySelector("[property~=articleId][content]").content,
"title": document.head.querySelector("[property~=ga4_title][content]").content,
"author": document.head.querySelector("[property~=ga4_author][content]").content,
"interest": document.head.querySelector("[property~=ga4_interest][content]").content,
"tags": gaTagsArr,
"main_column": document.head.querySelector("[property~=ga4_main_column][content]").content,
"other_columns": gaColsArr,
"publish_date": document.head.querySelector("[property~=ga4_publish_date][content]").content,
"days_since_publish": document.head.querySelector("[property~=ga4_days_since_publish][content]").content,
"is_360_article": document.head.querySelector("[property~=ga4_is_360_article][content]").content,
"login_status": window.ga4UserData.login_status,
"subscription": window.ga4UserData.subscription
}
dataLayer.push(artLoadEvt)
}
document.addEventListener("DOMContentLoaded", function() {
SetClosingControl()
scrollToHash()
SetAvailableUserFunctions()
SetGiftLinkNotificationIfNeeded()
initAuthors()
initInterests()
initShareButtons()
initContentObserver()
let isPremium = document.querySelector("main .article-details").classList.contains("isPremium")
if (isPremium) {
document.body.classList.add("isPremium")
}
doGa4Stuff()
})
</script><section class="card-section main-section" configurable="hvg:first-fold-6-3-3-manual:85e0d48c-e2da-4d84-992c-404575b66e1b">
