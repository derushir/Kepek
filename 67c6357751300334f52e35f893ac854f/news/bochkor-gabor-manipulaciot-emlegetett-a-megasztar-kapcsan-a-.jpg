data-numberOfSharesLeft="0"
></p>
<input type="text" id="copyInput" readonly>
<button id="copyButton" class="premium" data-translate-key="dialog.giftDialog.step2.buttonText"></button>
<p class="copiedToClipboard" data-translate-key="dialog.giftDialog.step2.resultText"
style="text-align:center; display: none;"></p>
