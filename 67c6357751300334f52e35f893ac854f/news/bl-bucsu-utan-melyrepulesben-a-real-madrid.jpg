<script>
    document.addEventListener('DOMContentLoaded', function() {
        var articles = document.querySelectorAll('.suggested-article-box a');
        var total = articles.length;
        var count = 2;

        var randomIndexes = [];
        while (randomIndexes.length < count && randomIndexes.length < total) {
            var rand = Math.floor(Math.random() * total);
            if (!randomIndexes.includes(rand)) {
                randomIndexes.push(rand);
            }
        }

        randomIndexes.forEach(function(i) {
            articles[i].style.display = '';

            if (typeof gtag !== 'undefined' && window.innerWidth < 768) {
                gtag('event', 'suggested_article_show', {title: articles[i].dataset.title, page_location: window.location.href, with_image: false});
            }
        });
    });
</script>
