<script>
jQuery(document).ready(function($){
   var checkExist = setInterval(function() {
   if ($('#videoad').length) {
      enableVideoAd();
      clearInterval(checkExist);
   }
}, 100);
});

function enableVideoAd(){
    var adUnit = $(".adunit[data-adunit='player_cikkek_leadalatt']");
    var iframe = adUnit.find('iframe');
    
    if (iframe.length > 0) {
        iframe.first().hide();
    }

    adUnit.css('height', '0px');
}


jQuery(document).ready(function($){
    if (typeof dataLayer !== 'undefined') {
        dataLayer.push({
            'post_author': 'Kolumbán Antal',
            'post_category': 'Sport',
            'post_publish_date': '2026-04-16'
        });
    }
    
    if (typeof gtag !== 'undefined') {
        var tags = ['foci', 'real madrid'];
        tags.forEach(function (tag) {
            gtag('event', 'select_content', {'page_tags': tag});
        });
    }
});
