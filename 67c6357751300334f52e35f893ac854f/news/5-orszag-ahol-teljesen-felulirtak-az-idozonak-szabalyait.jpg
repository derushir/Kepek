                        message:
                            '<div class="uk-margin-remove uk-text-bold uk-text-center">' +
                            response.message +
                            "</div>",
                        status: "danger",
                        pos: "top-center",
                        timeout: 3000,
                        });
                         setTimeout(() => {
                            target.innerHTML = '';
                        }, "3000");
                    } else {
                        target.innerHTML =
                        '<span class="uk-text-success">' + response.message + "</span>";
                                                UIkit.notification({
                        message:
                            '<div class="uk-margin-remove uk-text-bold uk-text-center">' +
                            response.message +
                            "</div>",
                        status: "success",
                        pos: "top-center",
                        timeout: 3000,
                        });
                        setTimeout(() => {
                            target.innerHTML = '';
                        }, "3000");
                    }
                    }
                }
                };
                xhr.open("POST", "/functions");
                xhr.send(formData);
            }}
            </script></div>
        </div>
      </div>
    </div>
  </div>
</div>



