                                window.iap_zones.push({"id":"adoceanindexhuplgfpsmnkt","empty":true,"lazy":false,"quality":true,"masterless":false,"area":"Port_Mozi_Aloldal_LB","events":{"loaded":false,"visible":false,"viewed":false},"stat":{"site":"port","path":"\/cikk\/mozi\/itt-a-kritika-amely-traumatizalta-quentin-tarantinot-a-karrierje-melypontjakent-elte-meg\/article-125132","type":"mozi\/cikk"},"porthu":{"id":"adoceanindexhuplgfpsmnkt","section":"mozi","type":"cikk","device":"desktop","zone":"superleaderboard"}});
