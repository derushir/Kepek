-elements-forms-success-background: rgba(57, 202, 106, 0.1); --theme-elements-forms-success-border: rgba(57, 202, 106, 0.4); --theme-elements-forms-success-icon: #39CA6A; --theme-elements-forms-warn-background: rgba(255, 136, 17, 0.1); --theme-elements-forms-warn-border: rgba(255, 136, 17, 0.4); --theme-elements-forms-warn-icon: #FF8811; --theme-elements-signIn-footer-border: rgba(211, 221, 217, 0.4); --theme-elements-faceoff-instructions-background: #181c25; --theme-elements-faceoff-instructions-caption: #d3ddd9; --theme-elements-faceoff-instructions-text: #f6f8f7; --theme-elements-tooltip-color: #181c25; --theme-elements-tooltip-background: #ffffff;;}</style><style id="__jsx-1166515047">#page.jsx-1166515047{display:-webkit-box;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;min-height:100%;}#main-content.jsx-1166515047{-webkit-flex:1 0 auto;-ms-flex:1 0 auto;flex:1 0 auto;}#ow-notifications-wrapper.jsx-1166515047{position:absolute;top:calc(var(--headerHeightMedium));right:70px;z-index:calc(var(--maxZIndex) + 1);}#ow-notifications-wrapper.sidebar.jsx-1166515047{right:unset;top:calc(50% - 245px);left:calc(50% + 180px);}#ow-notifications-wrapper.jsx-1166515047>#ow-notifications.jsx-1166515047{position:fixed;}header,footer{-webkit-flex-shrink:0;-ms-flex-negative:0;flex-shrink:0;}</style><style id="__jsx-4250020241">@media (min-width: 1281px){#page{margin-left:var(--sidebarWidth);}#page .fixed-header{width:calc(100% - var(--sidebarWidth));}}</style></head><body><script id="__NEXT_DATA__" type="application/json">{"props":{"pageProps":{"page":{"canonical":"/articles/metro-2039-first-look-reveal-roundup","routeName":"articles-show-slug","__typename":"ArticleContent","state":"Published","updatedAt":"2026-04-16T18:26:18.751Z","modifications":true,"comments":true,"ads":true,"headerImageUrl":null,"excerpt":"Publisher Deep Silver and developer 4A Games have brought a light up to Metro 2039 as part of an Xbox First showcase, revealing a first look at gameplay and a winter 2026 release window.","contributors":[{"__typename":"Contributor","authorId":5980476,"thumbnailUrl":"https://assets-prd.ignimgs.com/avatars/5205bf6a08586a205a834928/Michael_blue_red_2-1700460435246.png","id":"e989121d-b4b0-11ea-b2e3-0e7c1d759882","name":"Michael Cripe","nickname":"MikeCripe"}],"vertical":"Games","hrefLangs":{"en-sg":"https://sea.ign.com/metro-2039/241506/metro-2039-first-look-reveal-roundup","en-in":"https://in.ign.com/metro-2039/258565/metro-2039-first-look-reveal-roundup","en-pk":"https://pk.ign.com/metro-2039/254072/metro-2039-first-look-reveal-roundup","en-se":"https://nordic.ign.com/metro-2039/106381/metro-2039-first-look-reveal-roundup"},"eventSlugs":null,"events":null,"attributes":[{"__typename":"TypedAttribute","type":"Genre","attribute":{"__typename":"Attribute","name":"Shooter"}},{"__typename":"TypedAttribute","type":"Publisher","attribute":{"__typename":"Attribute","name":"Deep Silver"}},{"__typename":"TypedAttribute","type":"Platform","attribute":{"__typename":"Attribute","name":"TBA"}},{"__typename":"TypedAttribute","type":"Producer","attribute":{"__typename":"Attribute","name":"4A Games"}},{"__typename":"TypedAttribute","type":"Genre","attribute":{"__typename":"Attribute","name":"First-Person"}},{"__typename":"TypedAttribute","type":"Franchise","attribute":{"__typename":"Attribute","name":"Metro 2033"}}],"primaryObject":{"__typename":"Object","franchises":[{"__typename":"Attribute","name":"Metro 2033","slug":"metro-2033"}],"genres":[{"__typename":"Attribute","slug":"shooter"},{"__typename":"Attribute","slug":"first-person"}],"merchant":null,"affiliateLink":null,"objectRegions":[{"__typename":"ObjectRegion","releases":[{"__typename":"Release","id":"cdf2df49-da3e-4638-bbf1-64f0783af1d9","date":"2049-12-31","estimatedDate":true,"timeframeYear":"TBA/TBA","platformAttributes":[{"__typename":"Attribute","id":4476826,"name":"TBA","slug":"tba"}]}],"id":2398123,"name":null,"region":"US"}],"id":"d7b50efd-cdae-445f-abcf-da39c52dc080","url":"/games/metro-2039","slug":"metro-2039","type":"Game","metadata":{"__typename":"Metadata","names":{"__typename":"Names","name":"Metro 2039","alt":[],"short":null}}},"objects":[{"__typename":"Object","id":"d7b50efd-cdae-445f-abcf-da39c52dc080","url":"/games/metro-2039","slug":"metro-2039","type":"Game","merchant":null,"affiliateLink":null,"metadata":{"__typename":"Metadata","names":{"__typename":"Names","name":"Metro 2039","alt":[],"short":null}},"objectRegions":[{"__typename":"ObjectRegion","id":2398123,"name":null,"region":"US","releases":[{"__typename":"Release","id":"cdf2df49-da3e-4638-bbf1-64f0783af1d9","date":"2049-12-31","platformAttributes":[{"__typename":"Attribute","id":4476826,"name":"TBA"}]}]}],"franchises":[{"__typename":"Attribute","name":"Metro 2033","slug":"metro-2033"}]}],"seoTitle":"Metro 2039 First Look Reveal Roundup","ogTitle":"HereвҖҷs Everything Revealed at the Metro 2039 Xbox First Showcase","nonIndexable":false,"abTests":[{"__typename":"ABTest","id":66009,"represents":"promoTitle","values":["Metro 2039 First Look Reveal Roundup","Xbox First Look Reveals Metro 2039"],"winnerIndex":1}],"sponsorships":[],"contentCategory":{"__typename":"ContentCategory","id":1,"name":"News"},"brand":null,"sequenceNumber":null,"id":"bde195ad-aaaf-4f11-960a-fe0c134e6842","type":"Article","title":"Metro 2039 First Look Reveal Roundup - IGN","subtitle":"Out of the darkness.","promoteAt":null,"publishDate":"2026-04-16T18:26:17.278Z","slug":"metro-2039-first-look-reveal-roundup","feedTitle":"Metro 2039 First Look Reveal Roundup","feedImage":{"__typename":"Image","url":"https://assets-prd.ignimgs.com/2026/04/16/metro-2039-xbox-first-look-1776360296033.png"},"v3Id":null,"url":"/articles/metro-2039-first-look-reveal-roundup","heroVideoContentId":null,"heroVideoContentSlug":"","processedHtml":"\u003csection class=\"article-page\"\u003e\u003cp\u003ePublisher Deep Silver and developer 4A Games have brought a light up to \u003ca href=\"https://www.ign.com/games/metro-2039\"\u003e\u003cu\u003eMetro 2039\u003c/u\u003e\u003c/a\u003e as part of an Xbox First showcase, \u003ca href=\"https://www.ign.com/articles/metro-2039-announced-pc-ps5-and-xbox-series-xs-out-this-winter\"\u003erevealing\u003c/a\u003e a first look at gameplay and a winter 2026 release window.\u003c/p\u003e\u003csection data-transform=\"mobile-ad-break\"\u003e\u003c/section\u003e\u003cp\u003eWhere 2019вҖҷs Metro Exodus saw protagonist Artyom leave his life underground behind, the next game in the first-person survival shooter series features a new lead called The Stranger as they dig deeper into the Moscow Metro. These details and more were revealed during the 15-minute presentation, as Microsoft teamed up with the studio to show players a new, story-driven single-player entry for the franchise in seven years.\u003c/p\u003e\u003cp\u003eDuring the Xbox First Look, the debut trailer for Metro 2039 was revealed, which features our new main character as they endure a psychological battle in a radioactive wasteland. As chains wrap around them and pull them into darkness, we see them encountering supernatural elements that include a nuclear explosion, creepy ghost children, and the return of the Dark Ones.\u003c/p\u003e\u003csection data-transform=\"ignvideo\" data-slug=\"metro-2039-official-reveal-trailer\" data-loop=\"\"\u003e\u003c/section\u003e\u003cp\u003eThe Metro video game franchise is based on a series of books written by Dmitry Glukhovsky and encompasses \u003ca href=\"https://www.ign.com/games/metro-2033\"\u003e\u003cu\u003eMetro 2033\u003c/u\u003e\u003c/a\u003e, \u003ca href=\"https://www.ign.com/games/metro-last-light\"\u003e\u003cu\u003eMetro: Last Light\u003c/u\u003e\u003c/a\u003e, \u003ca href=\"https://www.ign.com/games/metro-exodus\"\u003e\u003cu\u003eMetro Exodus\u003c/u\u003e\u003c/a\u003e, a VR spinoff titled \u003ca href=\"https://www.ign.com/games/metro-awakening-vr\"\u003e\u003cu\u003eMetro Awakening\u003c/u\u003e\u003c/a\u003e, and, soon, Metro 2039. After more than 16 years in gamersвҖҷ hands, 4A is looking to keep the radioactive tunnels of its post-apocalyptic world looking grittier than ever thanks to the use of its 4A Engine.\u003c/p\u003e\u003cp\u003eвҖңMetro 2039 takes you to the dark heart of the Moscow Metro, where the last survivors of the nuclear apocalypse struggle to exist in the tunnels and subways of the ruined city,вҖқ co-creative director and lead audio designer Pavel Ulmer said regarding the gameвҖҷs story. вҖңHope is lost. The future looks bleak, if there is one.вҖқ\u003c/p\u003e\u003cp\u003eCreative director Andriy вҖҳmLsвҖҷ Shevchenko shared more about the plot: вҖңThe underground factions and station communities have all been united under one banner, the Novoreich, led by a new FГјhrer, the legendary Spartan, Hunter. FГјhrer promises a new life for the people, up on the surface. In reality, they are trapped down in the Metro, flooded with propaganda, misinformation, and fear. The people suffer under his authoritarian regime and the brutal belief if itвҖҷs hostile, you kill it.вҖқ\u003c/p\u003e\u003csection data-transform=\"slideshow\" data-slug=\"metro-2039-first-screenshots\" data-value=\"metro-2039-first-screenshots\" data-type=\"slug\" data-caption=\"\"\u003e\u003c/section\u003e\u003cp\u003eThe story of Metro 2039 is said to feature a вҖңmuch darker tone this time around,вҖқ with the Xbox First Look stream putting a spotlight on 4A and the \u003ca href=\"https://www.ign.com/articles/metro-exodus-developers-pay-tribute-to-colleague-killed-in-action-in-ukraine\"\u003econditions that have surrounded the development of the new game\u003c/a\u003e. Executive Producer Jon Bloch said that everything the team had planned for Metro changed in 2020 and again in 2022 with RussiaвҖҷs full-scale invasion of Ukraine.\u003c/p\u003e\u003cp\u003eShevchenko added that the events of the last few years have shaped Metro 2039 into something new, resulting in a handcrafted story told from a Ukrainian perspective. Additionally, its narrative was crafted in collaboration with Glukhovsky, who is \u003ca href=\"https://www.ign.com/articles/metro-2033-writer-added-to-russias-wanted-list-speaking-out-against-war\"\u003eliving in exile from Russia\u003c/a\u003e for criticizing the government and its invasion of Ukraine.\u003c/p\u003e\u003cp\u003eвҖңWe will push through no matter what,вҖқ Ulmer added. вҖңGetting electricity from generators or batteries. Power outages or sheltering from rocket and drone attacks are interrupting, but not stopping us from making what we deeply believe, what we do best. Of course, taking care of the family is the biggest priority. Sometimes you just put your head down and focus on work, but itвҖҷs each otherвҖҷs support that keeps you running.вҖқ\u003c/p\u003e\u003csection data-transform=\"ignvideo\" data-slug=\"metro-2039-trailer-breakdown-hidden-details-you-missed-ign-rewind-theater\" data-loop=\"\"\u003e\u003c/section\u003e\u003cp\u003eThe First Look wrapped up with a sneak peek at a video featuring a mix of gameplay and cinematics. ItвҖҷs footage that fans will find familiar, as we see The Stranger exploring tight spaces before coming into contact with one of the seriesвҖҷ many mutated creatures.\u003c/p\u003e\u003cp\u003eMetro 2039 launches this winter for PC, PlayStation 5, and Xbox Series X | S. While we wait for more updates, you can read our \u003ca href=\"https://www.ign.com/articles/2019/02/13/metro-exodus-review\"\u003e8.5/10 Metro Exodus review\u003c/a\u003e. At the time of its launch, we said that it вҖңbrings its survival horror to the surface without sacrificing any of the seriesвҖҷ signature tension.вҖқ\u003c/p\u003e\u003csection data-transform=\"divider\"\u003e\u003c/section\u003e\u003cp\u003e\u003cem\u003eMichael Cripe is a freelance writer with IGN. He\u0026#39;s best known for his work at sites like The Pitch, The Escapist, and OnlySP. Be sure to give him a follow on Bluesky (@mikecripe.bsky.social) and Twitter (@MikeCripe).\u003c/em\u003e\u003c/p\u003e\u003c/section\u003e","showCommerceDisclaimer":false,"review":null,"articleId":"bde195ad-aaaf-4f11-960a-fe0c134e6842","isCommunity":"no","resource":"article","pageType":"article","twitterCard":"summary_large_image","hasAds":true,"extraAds":false,"isPreview":false,"pageTitle":"Metro 2039 First Look Reveal Roundup","image":"https://assets-prd.ignimgs.com/2026/04/16/metro-2039-xbox-first-look-1776360296033.png?width=1280\u0026format=jpg\u0026auto=webp\u0026quality=80","description":"Publisher Deep Silver and developer 4A Games have brought a light up to Metro 2039 as part of an Xbox First showcase, revealing a first look at gameplay and a winter 2026 release window.","category":"News","categories":["News"],"objectId":"d7b50efd-cdae-445f-abcf-da39c52dc080","objectSlug":"metro-2039","genreSlugs":["shooter","first-person"],"platforms":["TBA"],"platformSlugs":["tba"],"franchiseNames":["Metro 2033"],"editPage":{"type":"article","params":{"id":"bde195ad-aaaf-4f11-960a-fe0c134e6842"}},"additionalDataLayer":{"content":{"contentId":"bde195ad-aaaf-4f11-960a-fe0c134e6842","objectIds":["d7b50efd-cdae-445f-abcf-da39c52dc080"]}},"commercePage":false,"articleType":"News","schema":{"@context":"http://schema.org/","mainEntityOfPage":{"@type":"WebPage","@id":"https://www.ign.com/articles/metro-2039-first-look-reveal-roundup"},"image":"https://assets-prd.ignimgs.com/2026/04/16/metro-2039-xbox-first-look-1776360296033.png?width=1280\u0026format=jpg\u0026auto=webp\u0026quality=80","url":"https://www.ign.com/articles/metro-2039-first-look-reveal-roundup","description":"Publisher Deep Silver and developer 4A Games have brought a light up to Metro 2039 as part of an Xbox First showcase, revealing a first look at gameplay and a winter 2026 release window.","@type":"NewsArticle","datePublished":"2026-04-16T18:26:17.278Z","headline":"Metro 2039 First Look Reveal Roundup - IGN","publisher":{"@type":"Or