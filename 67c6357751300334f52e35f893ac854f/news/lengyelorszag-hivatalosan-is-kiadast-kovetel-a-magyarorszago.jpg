<script>
const items = document.querySelectorAll(".list-item-author")
const moreButton = document.getElementById("remaining-count-author")
const visibleItemCount = config.articleDetails.numberOfVisibleAuthor
const remaining = items.length - visibleItemCount
if (remaining > 0) {
moreButton.setAttribute("data-remainingCount", remaining)
}
for (let i = 0; i < visibleItemCount; i++) {
if (items[i]) {
items[i].classList.remove(HIDDEN)
}
}
if (remaining > 0) {
moreButton.classList.remove(HIDDEN)
moreButton.addEventListener("click", function() {
setAuthorListItemVisible()
moreButton.setAttribute("aria-expanded", "true")
focusFirstRevealedAuthor()
})
moreButton.addEventListener("keydown", function(e) {
const isEnter = e.key === "Enter"
const isSpace = e.key === " " || e.key === "Spacebar" || e.code === "Space"
if (isEnter) {
e.preventDefault()
setAuthorListItemVisible()
moreButton.setAttribute("aria-expanded", "true")
requestAnimationFrame(() => focusFirstRevealedAuthor())
}
if (isSpace) {
e.preventDefault()
}
})
moreButton.addEventListener("keyup", function(e) {
const isSpace = e.key === " " || e.key === "Spacebar" || e.code === "Space"
if (isSpace) {
e.preventDefault()
setAuthorListItemVisible()
moreButton.setAttribute("aria-expanded", "true")
requestAnimationFrame(() => focusFirstRevealedAuthor())
}
})
} else {
moreButton.classList.add(HIDDEN)
}
function setAuthorListItemVisible() {
Array.from(items).forEach((item) => {
item.classList.remove(HIDDEN)
})
moreButton.classList.add(HIDDEN)
}
function focusFirstRevealedAuthor() {
const first = Array.from(items)
.slice(visibleItemCount)
.find(li => !li.classList.contains(HIDDEN))
if (!first) return
const focusable = first.querySelector('a,button,input,select,textarea,[tabindex]:not([tabindex="-1"])')
if (focusable) {
try { focusable.focus() } catch { (focusable).focus() }
} else {
first.setAttribute('tabindex', '-1')
first.addEventListener('blur', () => first.removeAttribute('tabindex'), { once: true })
try { first.focus() } catch { (first).focus() }
}
}
</script>
