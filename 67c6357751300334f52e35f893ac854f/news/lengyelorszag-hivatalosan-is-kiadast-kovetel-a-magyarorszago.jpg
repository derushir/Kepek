>
<dialog id="giftDialog" class="custom-dialog">
<div class="dialog-wrapper">
<div class="dialog-header">
<h3 class="dialog-title" data-translate-key="dialog.giftDialog.step1.title"></h3>
<button
class="btn icon-only dialog-close-button hover-inverse"
data-translations='{"aria-label": "general.close"}'
onclick="closeDialog('giftDialog')"
>
<span class="hvg-icon hvg-icon-x-close "


></span>
</button>
</div>
<div class="dialog-body">
<button class="step1 premium" onclick="sendGift()" data-translate-key="dialog.giftDialog.step1.buttonText"></button>
<div class="step2" style="display: none;">
<div id="loadingGiftDialogStep2" class="loading-box">
<div class="loading-ring">
<div id="loadingGiftDialogStep2" class="loader-box ">
<div class="loader-spinner"></div>
</div>
</div>
<div class="loading-body" style="display: none;">
<p
data-translate-key="dialog.giftDialog.step2.description"
data-translate-persist-key="dialog.giftDialog.step2.description"
data-numberOfSharesLeft="0"
></p>
<input type="text" id="copyInput" readonly>
<button id="copyButton" class="premium" data-translate-key="dialog.giftDialog.step2.buttonText"></button>
<p class="copiedToClipboard" data-translate-key="dialog.giftDialog.step2.resultText"
style="text-align:center; display: none;"></p>
</div>
</div>
</div>
</div>
</div>
</dialog>
<script>
const giftDialog = document.getElementById("giftDialog")
function sendGift() {
isLoading("loadingGiftDialogStep2")
giftDialog.querySelector(".step2").style.display = "block"
giftDialog.querySelector("button.step1").disabled = true
const articleId = document.head.querySelector("[property~=articleId][content]").content
const requestOptions = {
method: "POST",
credentials: "include",
headers: { "Content-Type": "application/json" },
body: JSON.stringify({ articleId: articleId })
}
fetch(window.msgwBaseUrl + "/api/profile/article-gift-link", requestOptions)
.then((response) => {
if (!response.ok) {
throw new Error(`HTTP error! Status: ${response.status}`)
}
return response.json()
})
.then(function(responseJson) {
giftDialog.querySelector(".step1").style.display = "none"
giftDialog.querySelector(".step2").style.display = "block"
giftDialog.querySelector(".dialog-title").innerText = translationsData.dialog.giftDialog.step2.title
const messagePara = giftDialog.querySelector(".step2 p")
messagePara.setAttribute("data-numberOfSharesLeft", responseJson.numberOfSharesLeft)
if (!messagePara.dataset.translateKey) {
messagePara.dataset.translateKey = messagePara.dataset.translatePersistKey
messagePara.removeAttribute("data-translate-persist-key")
}
let currentUrlWithoutQueryParams = window.location.href.split("?")[0]
copyInput.value = currentUrlWithoutQueryParams + "?giftId=" + responseJson.giftLinkId
initTranslations(giftDialog)
})
.catch(() => {
giftDialog.querySelector(".step1").style.display = "block"
giftDialog.querySelector(".step2").style.display = "none"
})
.finally(() => {
giftDialog.querySelector("button.step1").disabled = false
isLoading("loadingGiftDialogStep2", false)
})
}
const copyButton = giftDialog.querySelector("#copyButton")
const copyInput = giftDialog.querySelector("#copyInput")
copyButton.addEventListener("click", () => {
const szoveg = copyInput.value
navigator.clipboard.writeText(szoveg)
.then(() => {
giftDialog.querySelector(".copiedToClipboard").style.display = "block"
})
.catch(err => {
debugError("Hiba történt a másolás során:", err)
})
})
</script>
