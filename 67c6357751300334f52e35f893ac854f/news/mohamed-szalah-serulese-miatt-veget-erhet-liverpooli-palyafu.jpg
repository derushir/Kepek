                                                                                </script>
                                                                            </div>
                        </div><p>
                          <strong>szerdán játszották</strong>
                        </p>
                        <ul>
                        <li>Bournemouth–Leeds United 2–2 (0–0)</li>
                        <li>Burnley–Manchester City 0–1 (0–1)</li>
                        </ul>
                        <p>
                          <strong>kedden játszották</strong>
                        </p>
                        <ul>
                        <li>Brighton–Chelsea 3–0 (1–0)</li>
