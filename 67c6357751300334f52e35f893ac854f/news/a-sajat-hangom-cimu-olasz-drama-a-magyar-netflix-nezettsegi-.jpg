function CadmiumStrategy(player) {
    this.player_ = player;
    this.ready_ = false;
    this.currentAdPosition_ = undefined;
    this.videoPlayed_ = false;
    this.viewStartTime_ = (new Date()).getTime();
    this.videoStartTime_ = undefined;
    
    this.subscribeEvents_();
}

CadmiumStrategy.ContentType = {
    AD: 'ad',
    CONTENT: 'ct'
};

CadmiumStrategy.AdPosition = {
    PREROLL: 'a1',
    MIDROLL: 'a2',
    POSTROLL: 'a3',
    OVERLAY: 'a4',
    SPECIAL: 'a5'
};

CadmiumStrategy.VideoState = {
    UNPLAYED: 's1',
    PLAYED: 's2',
    STOPPED: 's3',
    COMPLETED: 's4'
};

CadmiumStrategy.prototype.subscribeEvents_ = function() {
    this.player_.addEventListener('loaded', this.onPlaybackReady_.bind(this));
    this.player_.addEventListener('playingchanged', this.onVideoPlay_.bind(this));
};

CadmiumStrategy.prototype.onPlaybackReady_ = function() {
    this.ready_ = true;
};

CadmiumStrategy.prototype.onVideoPlay_ = function() {
    this.videoStartTime_ = (new Date()).getTime();
    this.videoPlayed_ = true;
};

CadmiumStrategy.prototype.isReady = function() {
    return this.ready_;
};

CadmiumStrategy.prototype.getTitle = function() {
    return this.player_.videoTitle + " (" + this.player_.getMovieId() + ")";
};

CadmiumStrategy.prototype.getVideoPath = function() {
    return this.player_.slug;
};

CadmiumStrategy.prototype.getContentType = function() {
    return CadmiumStrategy.ContentType.CONTENT;
};

CadmiumStrategy.prototype.getAdPosition = function() {
    return '';
};

CadmiumStrategy.prototype.getTotalDuration = function() {
    return this.player_.getDuration();
};

CadmiumStrategy.prototype.getState = function() {
    if (!this.videoPlayed_) {
        return CadmiumStrategy.VideoState.UNPLAYED;
    }
    
    if (this.player_.isPaused()) {
        return CadmiumStrategy.VideoState.STOPPED;
    }
    
    if (this.player_.isPlaying()) {
        return CadmiumStrategy.VideoState.PLAYED;
    }
    
    return CadmiumStrategy.VideoState.UNPLAYED;
};

CadmiumStrategy.prototype.getCurrentPlayTime = function() {
    var currentTime = this.player_.getCurrentTime();
    return currentTime < 10 ? 0 : currentTime;
};

CadmiumStrategy.prototype.getBitrate = function() {
    return -1;
};

CadmiumStrategy.prototype.getThumbnailPath = function() {
    return this.player_.thumbnail;
};

CadmiumStrategy.prototype.getPlayerType = function() {
    return 'Cadmium';
};

CadmiumStrategy.prototype.getViewStartTime = function() {
    if (isNaN(this.viewStartTime_)) {
        return 0;
    }
    return this.timeElapsed_(this.viewStartTime_);
};

CadmiumStrategy.prototype.getViewPlayTime = function() {
    if (this.videoPlayed_) {
        return this.timeElapsed_(this.viewStartTime_);
    }
    return -1;
};

CadmiumStrategy.prototype.getViewAdPlayTime = function() {
    return -1;
};

CadmiumStrategy.prototype.getTimeInSeconds_ = function(t) {
    return ((t === -1 || isNaN(t)) ? -1 : t * 1000);
};

CadmiumStrategy.prototype.timeElapsed_ = function(timestamp) {
    if (timestamp === undefined) {
        return 0;
    }
    return (new Date()).getTime() - timestamp;
};

CadmiumStrategy.verify = function(player) {
    return true;
};


(function() {
    window['_cbv_strategies'] = window['_cbv_strategies'] || [];
    window['_cbv_strategies'].push(CadmiumStrategy);

