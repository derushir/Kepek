                    </script><style>[data-uia=freeform-banner] {
   box-shadow: none !important;
   filter: none !important;
}

[data-uia=freeform-banner] img {
   border-radius: 0;
}

.articleHeader img {
	align-self: flex-start;
}

.inlineVideo [data-uia=share-button]  {
	align-self: flex-start;
}

.articleHtmlContent h3 a {
    -webkit-text-decoration: underline;
    text-decoration: underline;
    text-decoration-color: var(--accent-color);
    -webkit-text-decoration-color: var(--accent-color);
    -webkit-transition: color 0.2s;
    transition: color 0.2s;
    text-underline-offset: 0.1em;
}

.articleHtmlContent h3 a:hover {
    color: var(--accent-color);
}

[data-guid="tudum-event-news"] {
	padding-top: 0 !important;
}

[data-guid="tudum-event-news"].smCard div [data-uia="card"] {
	--background-color: unset;
    --background-color-rgb: unset;
    --accent-color: unset;
    --accent-color-rgb: unset;
    --foreground-color: unset;
    --foreground-color-rgb: unset;
    --text-color: unset;
    --foreground-text-color: unset;
}

[data-guid="tudum-event-news"] > div:before {
	content: '';
	background-image: url(https://assets.nflxext.com/ffe/siteui/pulse/css/event/2022/banners/event-carousel-header-desktop.jpg);
	height: 310px;
	background-size: 100% auto;
    background-position: center top;
    background-repeat: no-repeat;
    position: relative;
    display: block;
    margin-bottom: -74px;
}

@media (max-width: 790px) {
	[data-guid="tudum-event-news"] > div:before {
		height: 31vw;
	    padding-left: 0;
	    left: -10px;
	    margin:  0;
	}
}

@media (max-width: 580px) {
	[data-guid="tudum-event-news"] > div:before {
		height: 58vw;
	    background-image: url(https://assets.nflxext.com/ffe/siteui/pulse/css/event/2022/banners/event-carousel-header-mobile.jpg);
	}
}

[data-id="2cuuLwz0HBZrmfdSWCrYce.hero.PageEmbed"] [data-uia="display-headline"] span {
	display: none;
}

[data-id="2cuuLwz0HBZrmfdSWCrYce.hero.PageEmbed"] [data-uia="display-headline"]:before,
[data-id="2cuuLwz0HBZrmfdSWCrYce.hero.PageEmbed"] [data-uia="display-headline"]:after {
	display: block;
	white-space: nowrap;
}

[data-id="2cuuLwz0HBZrmfdSWCrYce.hero.PageEmbed"] [data-uia="display-headline"]:before {
	content: 'Tudum: 넷플릭스 글로벌 팬 이벤트가';
}

[data-id="2cuuLwz0HBZrmfdSWCrYce.hero.PageEmbed"] [data-uia="display-headline"]:after {
	content: '찾아왔습니다';
}

@media (max-width: 480px) {
    [data-id="2cuuLwz0HBZrmfdSWCrYce.hero.PageEmbed"] [data-uia="display-headline"]:before,
	[data-id="2cuuLwz0HBZrmfdSWCrYce.hero.PageEmbed"] [data-uia="display-headline"]:after {
		font-size: 0.7em;
		line-height: 117%;
	}
}

[data-uia="section-site-header"].hideHeader {
    pointer-events: none;
}

[data-uia="add-to-my-list-button"] {
	background: rgba(var(--text-color-rgb), 0.1);
}

.modelViewer [data-sel="tools"] .css-x5u573 {
    font-family: "Netflix Sans Ex", sans-serif;
}

.articleHtmlContent[data-id="5CUdlTQ6ST6NvCofMU3kxM.PageEmbed"] [data-guid="free-form-banner-no-hover"],
.articleHtmlContent[data-id="5CUdlTQ6ST6NvCofMU3kxM.PageEmbed"] [data-guid="free-form-banner"] {
	padding-bottom: 0;
}

.stickyNav > div > div {
    border-top: 1px solid rgba(var(--text-color-rgb), 0.2);
    border-bottom: 1px solid rgba(var(--text-color-rgb), 0.2);
}

[data-guid="no-hover"] [data-uia="freeform-banner"] {
    filter: none;
}

.siteNav ul > div {
    white-space: nowrap;
}

@media (min-width: 1085px) {
    .page-kind-TAG [data-id="2nL8z2BfPKYgE6g9A8cgDx.6PQFNIY4VNrwLS2xZEttJG"].topicHero > div {
        padding-bottom: 80px;
    }

    .page-kind-TAG [data-id="2nL8z2BfPKYgE6g9A8cgDx.2ZfwtYzKE1zIXn1z2rvwEM"].medCard {
        margin-top: -120px;
    }
}

.articleHtmlContent .imageEntity video {
	max-width: 100%;
}

/* Safari Fix */
@container (min-width:375px) {
    .page .smCard [data-uia="cards"] {
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    }
    
    .page .smCard [data-uia="cards"][data-length="2"],
    .page .smCard [data-uia="cards"][data-length="3"],
    .page .medCard [data-uia="cards"] {
        grid-template-columns: repeat(auto-fill, minmax(335px, 1fr));
    }

    .page .smCard [data-uia="cards"][data-length="1"],
    .page .medCard [data-uia="cards"][data-length="1"] {
        grid-template-columns: 1fr;
    }
}

@container (min-width:1045px) {
    .page .medCard [data-uia="cards"] {
        grid-template-columns: repeat(auto-fill, minmax(335px, 1fr));
    }

    .page .smCard [data-uia="cards"] {
        grid-template-columns: repeat(auto-fill, minmax(225px, 1fr));
    }

    .page .smCard [data-uia="cards"][data-length="3"] {
        grid-template-columns: 1fr 1fr 1fr;
    }

    .page .smCard [data-uia="cards"][data-length="2"],
    .page .medCard [data-uia="cards"][data-length="2"] {
        grid-template-columns: 1fr 1fr;
    }
}

/* Safari Fix */

label[for="more-from-netflix"] {
    cursor: pointer;
}

.featuredCard h1 {
    max-width: 980px;
}

.page.page-kind-ARTICLE .stickyNav > div {
    max-width: 100vw;
}

.page-kind-TITLE #episodes [data-uia="sub-headline"] {
    display: block;
}

[data-id="1BRKazduaXNJA3p9IsAp5P.4yuiAQcPY7riCwyBe20h0B"] .title-visual-image > div > img {
  object-position: top center !important;
}

.css-199am41 {
	--accent-color: #D3317A;
	margin-top: calc(50vh - 32px);
}

[data-id="6km3gKqmTQbJRdWItgwlPY.PageEmbedHidden"] [data-sel="clock"] {
    display: none;
}

.episode-11 .css-ud4jhr {
    display: none;
}

section:not(.siteNav) [data-sel="drawer-content-wrapper"] [data-sel="drawer-content"] {
    max-width:710px;
}

.flexibleModule .section-title {
    font-size: 1.375rem;
    font-weight: 900;
    line-height: 110%;
    text-transform: uppercase;
}

[data-guid="site-subnav"] ul li:first-of-type {
  white-space: nowrap;
}

[data-guid="squid-game-leaderboard-iframe"] > div {
    max-width: 1200px !important;
    width: 100vw;
    transform: translateX(-50%);
    left: 50%;
    margin: 0 auto !important;
    position: relative;
}
[data-guid="squid-game-leaderboard-iframe"] > div > div {
    margin: 0 20px;
}

.queueBillboard img {
    object-position: top;
