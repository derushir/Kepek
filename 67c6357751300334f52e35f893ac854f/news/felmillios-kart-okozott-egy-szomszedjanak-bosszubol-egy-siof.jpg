    <script>
        (function() {
            const targetNode = document.body;
            if (!targetNode) return;

            const observer = new MutationObserver((mutations) => {
                mutations.forEach((mutation) => {
                    if (mutation.addedNodes.length) {
                        mutation.addedNodes.forEach((node) => {
                            if (node.nodeType === 1) {

                                // 1. Search for partial matches in class names
                                const isAdPoliticalNode = node.classList && Array.from(node.classList).some(cls => cls.includes('ad-political'));

                                const adContainers = isAdPoliticalNode ? [node] :
                                    (node.querySelectorAll ? node.querySelectorAll('[class*="ad-political"]') : []);

                                adContainers.forEach((container) => {
                                    const checkbox = container.querySelector('input[type="checkbox"].ad-toggle');

                                    if (checkbox && checkbox.id === 'ad-toggle') {
                                        // 2. Generate a unique ID
                                        const uniqueId = 'ad-toggle-' + Math.random().toString(36).substring(2, 9);

                                        // 3. Override the checkbox ID
                                        checkbox.id = uniqueId;

                                        // 4. Update the 'for' attribute of the corresponding labels
                                        const labels = container.querySelectorAll('label[for="ad-toggle"]');
                                        labels.forEach(label => {
                                            label.setAttribute('for', uniqueId);
                                        });

                                    }
                                });
                            }
                        });
                    }
                });
            });

            observer.observe(targetNode, {
                childList: true,
                subtree: true
            });
        })();
    </script>
  </body>
</html>


